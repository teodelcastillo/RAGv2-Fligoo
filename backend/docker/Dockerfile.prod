# ── Stage 1: build dependencies ──────────────────────────────────────
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /build

RUN pip install --no-cache-dir poetry

COPY pyproject.toml poetry.lock* ./
RUN poetry config virtualenvs.create false \
    && poetry config installer.parallel false \
    && poetry install --no-root --only main

# ── Stage 2: production image ───────────────────────────────────────
FROM python:3.12-slim AS production

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install only runtime dependencies (libpq for psycopg2)
RUN apt-get update \
    && apt-get install -y --no-install-recommends libpq5 curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r ecofilia && useradd -r -g ecofilia -d /app -s /sbin/nologin ecofilia

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY . /app

# Collect static files at build time (needs SECRET_KEY placeholder)
RUN SECRET_KEY=build-placeholder \
    POSTGRES_NAME=x POSTGRES_USER=x POSTGRES_PASSWORD=x POSTGRES_HOST=x POSTGRES_PORT=5432 \
    DJANGO_SETTINGS_MODULE=main.settings.prod \
    SQS_QUEUE_URL=https://placeholder \
    python manage.py collectstatic --noinput 2>/dev/null || true

# Set ownership
RUN chown -R ecofilia:ecofilia /app

USER ecofilia

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health/ || exit 1

# Default command (overridden per service in task definitions)
CMD ["gunicorn", "main.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "2", "--timeout", "120", "--access-logfile", "-", "--error-logfile", "-"]

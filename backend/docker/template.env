DJANGO_SETTINGS_MODULE=main.settings.dev

SECRET_KEY=change-me
DEBUG=True
# DEBUG=False

ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# IMPORTANTE: JWT_SIGNING_KEY debe ser consistente entre despliegues.
# Si cambia, los tokens existentes fallarán con TokenError.
# Usar: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SIGNING_KEY=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ALGORITHM=HS256

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
DRF_THROTTLE_RATE_ANON=30/min
DRF_THROTTLE_RATE_USER=120/min
DEFAULT_FROM_EMAIL=no-reply@ecofilia.site
EMAIL_BACKEND=django_ses.SESBackend
AWS_SES_REGION_NAME=us-east-2
FRONTEND_BASE_URL=http://localhost:3000
MFA_ISSUER_NAME=Ecofilia


# Para docker-compose local: el host es el servicio "db" del compose.
POSTGRES_NAME=postgres
POSTGRES_HOST=db
POSTGRES_PASSWORD=postgres1234
POSTGRES_USER=postgres
POSTGRES_PORT=5432
OPENAI_API_KEY=change-me
MODEL_EMBEDDING=text-embedding-3-small
MODEL_COMPLETION=gpt-4o-mini
CHAT_CONTEXT_CHUNKS=12
EVALUATION_CONTEXT_CHUNKS=8

# RAG retrieval precision — threshold below which chunks are discarded (0.0–1.0 cosine sim)
# Broad/panorama queries ignore this threshold automatically.
RAG_MIN_SIMILARITY=0.45

# RAG quality features — enable in production for better retrieval results
RAG_RERANKER_ENABLED=1
RAG_RERANK_POOL=25
RAG_QUERY_EXPANSION_ENABLED=1
RAG_MMR_ENABLED=0

# Evaluation parallelism — max concurrent metric evaluations per run
EVALUATION_MAX_WORKERS=6

# Copilot history — summary kicks in above SUMMARY_THRESHOLD total messages
COPILOT_HISTORY_MESSAGES=20
COPILOT_HISTORY_SUMMARY_THRESHOLD=25

SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/000000000000/eco-celery-sqs

AWS_STORAGE_BUCKET_NAME=files-s3
AWS_S3_REGION_NAME=us-east-2